// Dialogue 
COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/dialogue/_SAelar.d~
	
APPEND ~pdialog.2da~
~_SAelar~

UNLESS ~_SAelar~
UNLESS ~25POST~
