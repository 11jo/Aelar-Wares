/*******************************************************************************
*																			   *
* New store filled with magical items for Baldur's Gate II: Enhanced Edition!  *
*																			   *
********************************************************************************/ 

BACKUP ~weidu_external/backup/Aelar-Wares~
AUTHOR ~ShadowfireAngel at shadowfireangel346@gmail.com; alternatively reach out to ShadowfireAngel on Discord~

VERSION ~v1.4~
README ~Aelar-Wares/Readme-Aelar.txt~

AUTO_TRA ~%MOD_FOLDER%/translations/%s~

ALWAYS
  INCLUDE ~%MOD_FOLDER%/library/eet.tph~
  INCLUDE ~%MOD_FOLDER%/library/functions.tph~
END

LANGUAGE ~English~ ~English~ ~%MOD_FOLDER%/translations/English/items.tra~
							 ~%MOD_FOLDER%/translations/English/setup.tra~
		 
  // Installation of new NPC & store
BEGIN @1 //Aelar's Emporium of Magical Wonders - Enhanced Edition

APPEND ~STATE.IDS~ ~0x80101FEF CD_STATE_NOTVALID~
UNLESS ~CD_STATE_NOTVALID~

// CRE + WAV Installation
COPY ~%MOD_FOLDER%/creature/_SAelar.cre~ ~override/_SAelar.cre~
	SAY NAME1 @10 // Aelar 
	SAY NAME2 @10 // Aelar
	SAY INTERACTION1 @20 // The fair folk rarely have time for small talk.
	SAY INTERACTION2 @21 // Troubled times are upon us.
	SAY INTERACTION3 @22 // Soon we shall all be together on Evermeet.
	SAY DAMAGE ~~ [AelHurt]
	SAY DYING ~~ [AelDie]
	WRITE_ASCII DIALOG ~_SAelar~ #8
	WRITE_ASCII SCRIPT_OVERRIDE ~_SAelar~ #8 // script override
	WRITE_ASCII DEATHVAR ~_SAelar~ #32  //death variable

	
COPY ~%MOD_FOLDER%/sounds~ ~override~
COPY ~%MOD_FOLDER%/graphics~ ~override~
COPY ~%MOD_FOLDER%/spells~ ~override~
COPY ~%MOD_FOLDER%/effects~ ~override~
COPY ~%MOD_FOLDER%/area~ ~override~

// Add Map Note
COPY_EXISTING ~AR0700.are~ ~override~ //Athkatla
	ADD_MAP_NOTE #1486 #1758 ~gray~ @1000

// Store 
COPY ~%MOD_FOLDER%/stores~ ~override~
	SAY STORE_NAME @1 // Aelar's Emporium of Magical Wonders

// Items
COPY ~%MOD_FOLDER%/items/_SAEL001.itm~ ~override~
	SAY NAME1 @201 // Unidentifed Name
	SAY NAME2 @201 // Identified Name
	SAY UNIDENTIFIED_DESC @202 // Unidentifed Description
	SAY IDENTIFIED_DESC @202 // Identifed Description

COPY ~%MOD_FOLDER%/items/_SAEL002.itm~ ~override~
	SAY NAME1 @203 // Unidentifed Name
	SAY NAME2 @203 // Identified Name
	SAY UNIDENTIFIED_DESC @204 // Unidentifed Description
	SAY IDENTIFIED_DESC @204 // Identifed Description
	
