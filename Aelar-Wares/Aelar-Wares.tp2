	SAY NAME2 @217 // Identified Name
	SAY UNIDENTIFIED_DESC @218 // Unidentifed Description
	SAY IDENTIFIED_DESC @218 // Identifed Description

COPY ~%MOD_FOLDER%/items/_SAEL010.itm~ ~override~
